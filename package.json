{
	"name": "xp-tracker",
	"description": "A modern full-stack template powered by Cloudflare Workers, using Hono for backend APIs, React Router for frontend routing, and shadcn/ui for beautiful, accessible components styled with Tailwind CSS",
	"cloudflare": {
		"label": "React Router + Hono Fullstack App",
		"products": [
			"Workers"
		],
		"categories": [
			"starter"
		],
		"docs_url": "https://developers.cloudflare.com/workers",
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/d3db20ee-c3bf-4b5c-f1ed-d86021359e00/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/56caa8a9-d3ab-4ac6-32a9-6a5fc686e000/preview",
		"publish": true
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.106.0",
		"hono": "^4.12.23",
		"isbot": "5.1.32",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"react-router": "^7.16.0",
		"recharts": "^3.8.1"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.39.2",
		"@cloudflare/workers-types": "^4.20250425.0",
		"@react-router/dev": "^7.16.0",
		"@tailwindcss/vite": "4.1.17",
		"@types/node": "24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"tailwindcss": "4.1.17",
		"typescript": "5.9.3",
		"vite": "^6.0.0",
		"vite-tsconfig-paths": "5.1.4",
		"wrangler": "^4.97.0"
	},
	"private": true,
	"scripts": {
		"build": "react-router build",
		"cf-typegen": "wrangler types",
		"deploy": "npm run deploy:pages",
		"prepare:pages": "node -e \"const fs=require('fs'); fs.rmSync('build/client/wrangler.json',{force:true}); fs.rmSync('.wrangler/deploy/config.json',{force:true});\"",
		"deploy:pages": "npm run build && npm run prepare:pages && wrangler pages deploy build/client --project-name xp-tracker --branch main",
		"deploy:worker": "npm run build && wrangler deploy --config build/server/wrangler.json",
		"dev": "react-router dev",
		"preview": "npm run build && vite preview",
		"typecheck": "npm run cf-typegen && react-router typegen && tsc -b"
	},
	"type": "module"
}
